# SNTL Helium MCP — config is env-only (no UI).
SNTL_BASE=https://a2a.sntl.site
# BYO Solana secret key (JSON byte-array OR base58). Required ONLY for paid tools.
# Free tools (helium_ledger) work with this blank. We custody nothing — the caller pays.
WALLET_ENV=
RPC_URL=https://api.mainnet-beta.solana.com
# Hard spend cap per call (atomic guard). Default 1 USDC.
MAX_USDC_PER_CALL=1
